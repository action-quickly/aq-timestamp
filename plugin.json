{
  "id": "timestamp",
  "name": "时间戳转换",
  "version": "1.0.0",
  "author": "ActionQuick",
  "description": "Unix 时间戳与日期互转",
  "icon": "icon.png",
  "main": "index.html",
  "keywords": ["timestamp", "时间戳", "unix", "time", "sjc"],
